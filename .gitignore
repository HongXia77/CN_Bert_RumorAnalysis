frontend/node_modules/
# 忽略前端打包产物
frontend/dist/
# 忽略前端本地环境配置
frontend/.env.local
frontend/.env.*.local
# 忽略前端日志和缓存
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.vscode/

